# DeepSeek(OpenAI 兼容)密钥 —— 必填, 请填入真实值, 勿提交到版本库
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI 兼容端点(中转站 base url)
DEEPSEEK_BASE_URL=https://api.xinyunai.net/v1

# 模型(该中转 key 提供 gpt-5.5 / claude 系列; deepseek 不可用)
MODEL=gpt-5.5

# 生成参数
MAX_TOKENS=2048
TEMPERATURE=0.6
REQUEST_TIMEOUT=30

# 缓存过期秒数(0=永不过期)
CACHE_TTL=21600
