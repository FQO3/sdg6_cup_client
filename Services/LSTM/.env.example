# SQLite 数据库路径，默认 Services/LSTM/lstm_readings.db
# LSTM_DB_PATH=./lstm_readings.db

# 模型目录，默认 Services/LSTM/models
# MODEL_DIR=./models

# 训练触发策略
SEQ_LEN=8
MIN_TRAIN_POINTS=20
TRAIN_EVERY_NEW_POINTS=10
MAX_TRAIN_POINTS=5000
RANDOM_KEEP_RATIO=0.8
TRAIN_EPOCHS=20
BATCH_SIZE=64

# 异常 / 趋势判断阈值
ANOMALY_Z_THRESHOLD=2.5
TREND_DEADBAND_RATIO=0.01

# LLM 直连(OpenAI 兼容)配置：不依赖 Services/LLM:8090
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.xinyunai.net/v1
MODEL=gpt-5.5
MAX_TOKENS=2048
TEMPERATURE=0.6
REQUEST_TIMEOUT=30